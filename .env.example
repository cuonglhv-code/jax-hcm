# Database
DATABASE_URL=postgresql://hcm_user:secret@localhost:5432/hcm_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hcm_db
DB_USER=hcm_user
DB_PASSWORD=secret

# Auth
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_32_CHAR_MIN
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Server
PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# File storage
FILE_STORAGE_PATH=./uploads
FILE_STORAGE_PROVIDER=local

# Company
COMPANY_NAME=Jaxtina Ltd
COMPANY_CURRENCY=GBP
COMPANY_TIMEZONE=Europe/London
