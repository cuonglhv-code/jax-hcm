# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/jax_hcm
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Auth ──────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_32_CHAR_MINIMUM_RANDOM_STRING
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
BCRYPT_ROUNDS=12

# ── Server ────────────────────────────────────
PORT=4000
NODE_ENV=production
CLIENT_URL=http://localhost:5173

# ── File Storage ──────────────────────────────
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_PATH=./uploads
# For S3 (set FILE_STORAGE_PROVIDER=s3):
# AWS_BUCKET_NAME=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Company ───────────────────────────────────
COMPANY_NAME=Jaxtina HCM
COMPANY_JURISDICTION=GB
