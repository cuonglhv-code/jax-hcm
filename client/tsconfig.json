{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@hcm/shared": ["../shared/src"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/shared/**/*",
    "src/layouts/**/*",
    "src/router/**/*",
    "src/contexts/**/*",
    "src/services/**/*",
    "src/pages/**/*",
    "src/test/**/*",
    "src/i18n/**/*"
  ],
  "exclude": ["node_modules"]
}
